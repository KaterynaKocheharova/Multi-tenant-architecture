graph TD

  subgraph Shared Database
    DB[(PostgreSQL)]

    Users[Users]
    Events[Events]
    Participation[Participation]
    Lessons[Lesson Plans]

    Users --> DB
    Events --> DB
    Participation --> DB
    Lessons --> DB
  end

  subgraph Tenant Isolation
    RLS[Row-Level Security]
    TenantContext[app.current_tenant]

    TenantContext --> RLS
    RLS --> DB
  end

  subgraph Application Layer
    API[Backend API]
    Prisma[Prisma Client Extension]

    API --> Prisma
    Prisma --> DB
  end

  subgraph Tenants
    SchoolA[School A]
    SchoolB[School B]
    SchoolC[School C]
  end

  SchoolA --> API
  SchoolB --> API
  SchoolC --> API

  subgraph Cross-Tenant Collaboration
    EventGlobal[Global Event]
    ParticipationA[A Participation]
    ParticipationB[B Participation]

    EventGlobal --> ParticipationA
    EventGlobal --> ParticipationB
  end