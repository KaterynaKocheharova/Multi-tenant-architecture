flowchart TD

    REQ(["HTTP request"])
    S1["1. Get userId"]
    S2["2. Find user"]
    S3["3. Find membership"]
    S4["4. Get schoolId from membership"]
    S5["5. Attach user + schoolId to req"]
    S6["6. Start DB request"]
    S7["7. Set globalRole + tenantId in request context"]
    S8["8. Make request"]
    S9{"9. Tenants match\nand event is not global?"}
    OK["Executed"]
    DENY["Empty data returned\nor error"]

    REQ --> S1 --> S2 --> S3 --> S4 --> S5 --> S6 --> S7 --> S8 --> S9
    S9 -->|yes| OK
    S9 -->|no| DENY

    classDef step fill:#E3F2FD,stroke:#1565C0,color:#000
    classDef decision fill:#FFF3E0,stroke:#EF6C00,color:#000
    classDef ok fill:#E8F5E9,stroke:#2E7D32,color:#000
    classDef deny fill:#FFEBEE,stroke:#C62828,color:#000

    class REQ,S1,S2,S3,S4,S5,S6,S7,S8 step
    class S9 decision
    class OK ok
    class DENY deny
